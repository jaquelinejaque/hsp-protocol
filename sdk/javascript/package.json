{
  "name": "@hsp-protocol/sdk",
  "version": "1.0.0",
  "description": "Official JavaScript SDK for the Human Supervision Protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.esm.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
