    "eu-ai-act",
    "compliance"
  ],
  "author": "HSP Protocol Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaquelinejaque/hsp-protocol.git"
  },
  "homepage": "https://hsp-protocol.org",
  "bugs": {
    "url": "https://github.com/jaquelinejaque/hsp-protocol/issues"
  },
  "dependencies": {
    "ethers": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
